{
  "id": "generic-example-task",
  "version": "1.0.0",
  "title": "Generic Example Task",
  "difficulty": "intermediate",
  "category": "general",
  "summary": "Demonstration task kit template for CasePrac evaluation platform.",
  "description": "Implement a generic dashboard interface matching design specs and API contracts.",
  "includeReferenceSource": false,
  "devCommand": "npm run dev",
  "submission": {
    "startPath": "/generic-example-task",
    "requiredRoutes": [
      "/generic-example-task"
    ]
  },
  "viewports": [
    {
      "id": "desktop",
      "width": 1440,
      "height": 900
    },
    {
      "id": "mobile",
      "width": 390,
      "height": 844
    }
  ],
  "evaluation": {
    "timeoutMs": 120000,
    "visual": {
      "enabled": true,
      "maxDiffPixelRatio": 0.02,
      "threshold": 0.2
    },
    "functional": {
      "enabled": true
    },
    "accessibility": {
      "enabled": true,
      "maxViolations": 0
    }
  },
  "scoring": {
    "visualWeight": 50,
    "functionalWeight": 40,
    "accessibilityWeight": 10
  }
}
